---
import Layout from '../../layouts/Layout.astro';
import TerminalCard from '../../components/TerminalCard.astro';
import { getCollection } from 'astro:content';
import { getI18nPaths } from '../../i18n/utils';

export function getStaticPaths() {
  return getI18nPaths();
}

const currentLocale = Astro.currentLocale === 'en' ? 'en' : 'pl';

const projects = await getCollection('projects');
// Sort by date descending
projects.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const translations = {
  pl: {
    title: 'Projekty',
    header: './projekty',
    subtitle: 'Rzeczy, które zbudowałem po godzinach.',
  },
  en: {
    title: 'Projects',
    header: './projects',
    subtitle: 'Things I built after hours.',
  }
};

const t = translations[currentLocale];
---

<Layout title={t.title}>
    <main class="main-content">
        <header class="page-header">
            <h1 class="page-title">{t.header}</h1>
            <p class="page-subtitle">{t.subtitle}</p>
        </header>
        <div class="grid-list">
            {projects.map(post => (
                <TerminalCard post={post} />
            ))}
        </div>
    </main>
</Layout>

<style>
    .page-header {
        margin-bottom: var(--spacing-xl);
    }
    .page-title {
        font-size: 3rem;
        color: var(--color-matrix);
        margin-bottom: var(--spacing-sm);
    }
    .page-subtitle {
        font-size: 1.2rem;
        color: var(--color-light);
    }
    .grid-list {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
        max-width: 900px;
        margin: 0 auto;
    }
</style>
