---
import Layout from '../../layouts/Layout.astro';
import TerminalFrame from '../../components/TerminalFrame.astro';
import { getI18nPaths } from '../../i18n/utils';

export function getStaticPaths() {
  return getI18nPaths();
}

const currentLang = Astro.currentLocale === 'en' ? 'en' : 'pl';

const content = {
  pl: {
    title: 'whoami',
    header: 'whoami',
    subtitle: 'Inicjalizacja profilu użytkownika...',
    terminalTitle: 'profile.sh — 80x24',
    commandPrompt: 'dev@matrix:~$',
    catCommand: 'cat user_profile.md',
    greeting: 'Cześć, jestem Konrad.',
    doingTitle: 'Co robię?',
    doingItems: [
      {
        label: 'Hardware & Networking:',
        text: 'Zarządzam rozbudowanym Home Labem opartym na serwerach SuperMicro oraz urządzeniach Mikrotik (L009, AX2, AX S). Sieci to dla mnie nie tylko połączenia, ale architektura, którą stale optymalizuję.'
      },
      {
        label: 'Automatyka:',
        text: 'Tworzę inteligentne rozwiązania domowe oparte o system SUPLA, integrując elektronikę z codzienną wygodą.'
      },
      {
        label: 'Software:',
        text: 'Na co dzień korzystam z Linux Mint, a moje narzędzia pracy to VS Code, Docker i Git. Buduję projekty, które są szybkie, proste i funkcjonalne – dokładnie tak jak ta strona.'
      }
    ],
    philosophyTitle: 'Filozofia pracy',
    philosophyText: 'Wierzę w podejście "Vanilla First" – zarówno w kodzie, jak i w życiu. Cenię proste, niezawodne rozwiązania, które dają pełną kontrolę nad systemem. Moje portfolio to zapis drogi od prostych skryptów po złożone systemy automatyki domowej.'
  },
  en: {
    title: 'whoami',
    header: 'whoami',
    subtitle: 'Initializing user profile...',
    terminalTitle: 'profile.sh — 80x24',
    commandPrompt: 'dev@matrix:~$',
    catCommand: 'cat user_profile.md',
    greeting: "Hi, I'm Konrad.",
    doingTitle: 'What do I do?',
    doingItems: [
      {
        label: 'Hardware & Networking:',
        text: 'I manage an extensive Home Lab based on SuperMicro servers and Mikrotik devices (L009, AX2, AX S). Networking for me is not just connections, but an architecture I constantly optimize.'
      },
      {
        label: 'Automation:',
        text: 'I create smart home solutions based on the SUPLA system, integrating electronics with daily convenience.'
      },
      {
        label: 'Software:',
        text: 'Daily I use Linux Mint, and my tools of trade are VS Code, Docker, and Git. I build projects that are fast, simple, and functional – exactly like this website.'
      }
    ],
    philosophyTitle: 'Work Philosophy',
    philosophyText: 'I believe in the "Vanilla First" approach – both in code and in life. I value simple, reliable solutions that give full control over the system. My portfolio is a record of my journey from simple scripts to complex home automation systems.'
  }
};

const t = content[currentLang];
---

<Layout title={t.title}>
  <main class="main-content animate-fadeIn">
    <header class="page-header">
      <h1 class="page-title">{t.header}</h1>
      <p class="page-subtitle">{t.subtitle}</p>
    </header>

    <TerminalFrame title={t.terminalTitle} class="max-w-900">
      <div class="terminal-body-content">
        <div class="terminal-line">
          <span class="prompt">{t.commandPrompt}</span> <span class="command">{t.catCommand}</span>
        </div>
        
        <div class="profile-content">
          <h2 class="matrix-text">{t.greeting}</h2>
          
          <h3 class="matrix-text">{t.doingTitle}</h3>
          <ul>
            {t.doingItems.map(item => (
              <li><strong>{item.label}</strong> {item.text}</li>
            ))}
          </ul>

          <h3 class="matrix-text">{t.philosophyTitle}</h3>
          <p>{t.philosophyText}</p>
        </div>

        <div class="terminal-line">
          <span class="prompt">{t.commandPrompt}</span> <span class="cursor">█</span>
        </div>
      </div>
    </TerminalFrame>
  </main>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }
  .page-title {
    font-size: 3rem;
    color: var(--color-matrix);
    margin-bottom: var(--spacing-sm);
  }
  .page-subtitle {
    font-size: 1.2rem;
    color: var(--color-light);
  }

  .max-w-900 {
    max-width: 900px;
    margin: 0 auto;
  }

  .terminal-line {
    margin-bottom: var(--spacing-md);
  }

  .prompt {
    color: var(--color-matrix);
    font-weight: bold;
  }

  .command {
    color: var(--color-white);
  }

  .matrix-text {
    color: var(--color-matrix);
    border-bottom: 1px solid rgba(0, 255, 65, 0.2);
    padding-bottom: 4px;
    margin-top: var(--spacing-lg);
    font-size: 1.4rem;
  }

  .profile-content ul {
    list-style: none;
    padding: 0;
  }

  .profile-content li {
    margin-bottom: var(--spacing-md);
    padding-left: 1.5rem;
    position: relative;
    color: var(--color-light);
  }

  .profile-content li::before {
    content: ">";
    position: absolute;
    left: 0;
    color: var(--color-matrix);
  }

  .profile-content p {
    color: var(--color-light);
    line-height: 1.6;
  }

  .cursor {
    animation: blink 1s infinite;
    color: var(--color-matrix);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
